# eyebrain configuration — copy to .env and fill in.
# The vision + retrieval + synthesis core runs fully on-device (Ollama) and needs NONE of these.
# These are only for the LiveKit voice interface.

# --- Ollama (local, on-device) ---
EYEBRAIN_OLLAMA_HOST=http://localhost:11434
EYEBRAIN_VLM_MODEL=qwen2.5vl:3b
EYEBRAIN_LLM_MODEL=qwen2.5:3b
EYEBRAIN_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval backend: local (fastembed, offline) or moss (sponsor runtime) ---
EYEBRAIN_RETRIEVER=local
# Moss: free at portal.usemoss.dev. Cameras send only compact captions, never video.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# --- LiveKit (voice interface) ---
# Redeem $50 credits: cloud.livekit.io -> Redeem -> code HACK-MOSS-YC
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- STT (pick one) ---
DEEPGRAM_API_KEY=

# --- TTS: MiniMax (sponsor) ---
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
